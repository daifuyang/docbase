# =============================================================================
# DocBase — Environment Variables
# Copy to .env and fill in the values
# =============================================================================

# ----- Application -----
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000

# ----- Database (PostgreSQL) -----
# Used by Docker Compose service AND by the app at runtime
POSTGRES_USER=docbase
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=docbase
DATABASE_URL=postgres://docbase:change_me_in_production@postgres:5432/docbase

# ----- Cache / Queue (Redis) -----
REDIS_URL=redis://redis:6379

# ----- Auth (better-auth) -----
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace_me_with_64_hex_chars_min_32_bytes
BETTER_AUTH_URL=http://localhost:3000

# ----- Logging -----
LOG_LEVEL=info
NODE_ENV=development
