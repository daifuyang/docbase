#!/usr/bin/env bash
set -euo pipefail

cd /code

export NODE_ENV="${NODE_ENV:-production}"
export PORT="${PORT:-9000}"

# DB migrations are applied by `.github/workflows/deploy.yml` before the
# function is republished (runner walks the VPC and runs `drizzle-kit
# migrate` against APP_DB_URL). If a manual deploy skips that step the
# runtime will surface the schema mismatch as a 500 — fail-fast is the
# right call so ops notices via the smoke check immediately.

exec node .output/server/index.mjs
