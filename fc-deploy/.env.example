# =============================================================================
# fc-deploy/ 本地测试用 env 模板
# =============================================================================
# 用法：
#   cp .env.example .env
#   vim .env               # 填写真实值
#   s local start --env-file .env
#
# - DATABASE_URL / REDIS_URL / BETTER_AUTH_SECRET / BETTER_AUTH_URL / PUBLIC_APP_URL
#   必须填真实值（连得到 PG/Redis 才能 /api/health 通过）
# - VPC_ID / VSWITCH_ID / SECURITY_GROUP_ID 是 placeholder 也行
#   （fc3 custom-runtime local 不会调用 FC API，不会连 VPC）
# =============================================================================

# ----- Application -----
NODE_ENV=production
DOCBASE_DEPLOY_MODE=fc
PUBLIC_APP_URL=http://localhost:9000
BETTER_AUTH_URL=http://localhost:9000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:9000
LOG_LEVEL=info

# ----- 安装锁 -----
# DOCBASE_INSTALLED=true：跳过 /install 向导，根路由直接渲染业务页面（生产模式）
# DOCBASE_INSTALLED=false 或 unset：访问 / 会被重定向到 /install 向导（首次部署用）
# fc-deploy/s.yaml 里默认设 'true'（生产部署），本地 s local start 时可以临时改 'false' 走安装流程。
DOCBASE_INSTALLED=true

# ----- Database（必须可连通）-----
DATABASE_URL=postgres://docbase_app:change-me@127.0.0.1:5432/docbase
# 可选：生产迁移专用账号。留空时发布脚本会回退到 DATABASE_URL。
MIGRATE_DATABASE_URL=postgres://docbase_migrator:change-me@127.0.0.1:5432/docbase

# ----- Cache / Queue（必须可连通）-----
REDIS_URL=redis://:change-me@127.0.0.1:6379

# ----- Auth（≥32 字符）-----
BETTER_AUTH_SECRET=change-me-to-a-64-character-random-hex-string

# ----- Production admin（pnpm deploy / pnpm admin:ensure 使用）-----
DOCBASE_ADMIN_EMAIL=admin@example.com
DOCBASE_ADMIN_USERNAME=admin
DOCBASE_ADMIN_DISPLAY_NAME=Admin
DOCBASE_ADMIN_PASSWORD=change-me-to-a-strong-password
# 默认 false：已有账号只确保 admin 角色，不改密码。
DOCBASE_ADMIN_RESET_PASSWORD=false

# ----- 线上发版时才会用到，s local 不校验（placeholder 即可）-----
VPC_ID=vpc-local-placeholder
VSWITCH_ID=vsw-local-placeholder
SECURITY_GROUP_ID=sg-local-placeholder
