{
  "name": "docbase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "NODE_ENV=production vite build",
    "start": "node .output/server/index.mjs",
    "build:fc": "node scripts/build-fc.mjs",
    "build:fc:local": "pnpm build && node scripts/build-fc.mjs",
    "deploy:local": "DOCBASE_FC_ENV_FILE=fc-deploy/.env bash scripts/deploy-fc.sh local",
    "deploy": "bash scripts/deploy-fc.sh apply",
    "deploy:fc": "bash scripts/deploy-fc.sh apply",
    "deploy:release": "DOCBASE_RUN_PREFLIGHT=1 DOCBASE_RUN_MIGRATIONS=1 DOCBASE_RUN_ADMIN_ENSURE=1 bash scripts/deploy-fc.sh apply",
    "deploy:dry": "bash scripts/deploy-fc.sh plan",
    "deploy:info": "bash scripts/deploy-fc.sh info",
    "deploy:rollback": "bash scripts/deploy-fc.sh rollback",
    "deploy:smoke": "bash scripts/deploy-fc.sh smoke",
    "deploy:preflight": "bash scripts/deploy-fc.sh preflight",
    "db:migrate:prod": "bash scripts/deploy-fc.sh migrate",
    "admin:ensure": "bash scripts/deploy-fc.sh admin",
    "cli:connect": "bash scripts/restish-connect.sh",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "drizzle-kit drop && pnpm db:migrate && pnpm db:seed",
    "prepare": "husky"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.6.22",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-start": "^1.95.0",
    "@tiptap/core": "^2.10.0",
    "@tiptap/extension-image": "^2.10.0",
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/html": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/react": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.0",
    "ioredis": "^5.4.1",
    "isbot": "^5.1.17",
    "lucide-react": "^0.460.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "sanitize-html": "^2.13.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.18.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@hookform/resolvers": "^5.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.95.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.13.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "commitlint": "^19.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.10",
    "nitro": "3.0.260610-beta",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vinxi": "^0.5.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.0.0",
    "vitest": "^3.0.0",
    "zod-to-json-schema": "^3.23.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "biome check --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@parcel/watcher",
      "@scarf/scarf",
      "@tree-sitter-grammars/tree-sitter-yaml",
      "core-js-pure",
      "esbuild",
      "tree-sitter",
      "tree-sitter-json"
    ]
  }
}
